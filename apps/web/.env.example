# ─────────────────────────────────────────────────────────────────────────────
# Reels — Environment Variables
# Copy this file to `.env.local` for local development.
# Set these as Environment Variables in Vercel for production deployment.
#
# REQUIRED for any environment:
#   DATABASE_URL, BETTER_AUTH_SECRET, TMDB_API_READ_ACCESS_TOKEN, RESEND_API_KEY, SMTP_FROM
#
# OPTIONAL (social sign-in is disabled when not set):
#   GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET
#   APPLE_CLIENT_ID, APPLE_CLIENT_SECRET
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string.
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Get this from: Supabase Dashboard → Settings → Database → Connection string → URI (Transaction pooler)
DATABASE_URL="postgresql://postgres.YOURREF:YOURPASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# ── Authentication ────────────────────────────────────────────────────────────
# BetterAuth secret — MUST be at least 32 random characters in production.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="REPLACE_WITH_OPENSSL_RAND_BASE64_32_OUTPUT"

# The public URL of your deployed app. Used by BetterAuth for redirect URLs.
# Local: http://localhost:3000   Production: https://your-app.vercel.app
BETTER_AUTH_URL="http://localhost:3000"

# ── Email (Resend — free tier: 3,000 emails/month) ───────────────────────────
# Sign up at https://resend.com — free, no credit card needed.
# Create an API key under API Keys → Create API Key.
RESEND_API_KEY="re_REPLACE_WITH_YOUR_RESEND_API_KEY"

# The "From" address for transactional emails.
# In Resend free tier, use their onboarding domain: onboarding@resend.dev
# For custom domain, verify it in Resend → Domains → Add Domain.
SMTP_FROM="Reels <onboarding@resend.dev>"

# ── Film Metadata (TMDB — completely free) ───────────────────────────────────
# Sign up at https://www.themoviedb.org/signup — completely free.
# Go to Settings → API → Request an API Key → Developer.
# Use the "API Read Access Token" (Bearer token), not the API key.
TMDB_API_READ_ACCESS_TOKEN="eyJhbGciOiJSUzI1NiJ9.REPLACE_WITH_YOUR_TMDB_BEARER_TOKEN"

# ── Storage (Supabase Storage — free, included with Supabase) ────────────────
# Your Supabase project URL (found in Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://YOURREF.supabase.co"
# Supabase anon/public key (found in Settings → API → anon public key)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE"

# ── Social Sign-In (OPTIONAL — app works without these via magic link) ────────
# Leave blank to disable Google sign-in.
# Setup: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Leave blank to disable Apple sign-in.
# Setup requires Apple Developer account ($99/year).
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# ── iOS Push Notifications (OPTIONAL) ────────────────────────────────────────
# Apple Push Notification service credentials.
# Needed only for production iOS push notifications.
APNS_KEY_ID=""
APNS_TEAM_ID=""
APNS_PRIVATE_KEY=""
