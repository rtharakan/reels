generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Intent {
  FRIENDS
  DATING
  BOTH
}

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE_CONTENT
  FAKE_PROFILE
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  ACTIONED
  DISMISSED
}

model User {
  id                       String    @id @default(cuid())
  email                    String    @unique
  emailVerified            Boolean   @default(false)
  name                     String
  image                    String?
  age                      Int?
  location                 String?
  bio                      String?
  intent                   Intent?
  timezone                 String?
  letterboxdUsername        String?   @unique
  profilePhotos            String[]
  prompts                  Json?
  topFilmIds               String[]
  privacyPolicyConsentedAt DateTime?
  onboardingCompletedAt    DateTime?
  deletedAt                DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  // BetterAuth relations
  sessions Session[]
  accounts Account[]

  // App relations
  watchlistEntries  WatchlistEntry[]
  watchedEntries    WatchedEntry[]
  ratingEntries     RatingEntry[]
  likedEntries      LikedEntry[]
  interestsSent     Interest[]       @relation("InterestFrom")
  interestsReceived Interest[]       @relation("InterestTo")
  matchesAsA       Match[]          @relation("MatchUserA")
  matchesAsB       Match[]          @relation("MatchUserB")
  blocksCreated    Block[]          @relation("Blocker")
  blocksReceived   Block[]          @relation("Blocked")
  reportsMade      Report[]         @relation("Reporter")
  reportsReceived  Report[]         @relation("Reported")
  matchScoresAsUser      MatchScore[] @relation("ScoreUser")
  matchScoresAsCandidate MatchScore[] @relation("ScoreCandidate")
  seenUsers        SeenUser[]       @relation("Viewer")
  seenByUsers      SeenUser[]       @relation("Seen")
  dailyAllocations DailyAllocation[]
  deviceTokens     DeviceToken[]
  buddyRequests    BuddyRequest[]   @relation("BuddyRequestCreator")
  buddyInterests   BuddyInterest[]  @relation("BuddyInterestUser")
  buddyMessages    BuddyMessage[]   @relation("BuddyMessageSender")

  // Picker & Mood relations
  pickerPlans            PickerPlan[]          @relation("PickerPlanOrganizer")
  pickerParticipations   PickerParticipant[]
  moods                  UserMood[]
  moodSuggestions        MoodFilmSuggestion[]
  moodTags               MoodFilmTag[]

  @@index([deletedAt])
  @@index([intent])
  @@index([onboardingCompletedAt])
  @@index([onboardingCompletedAt, deletedAt])
  @@index([intent, onboardingCompletedAt])
}

// BetterAuth Session model
model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// BetterAuth Account model
model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// BetterAuth Verification model (for magic links)
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Film {
  id         String   @id @default(cuid())
  tmdbId     Int?     @unique
  title      String
  year       Int?
  posterPath String?
  genreIds   Int[]
  createdAt  DateTime @default(now())

  watchlistEntries WatchlistEntry[]
  watchedEntries   WatchedEntry[]
  ratingEntries    RatingEntry[]
  likedEntries     LikedEntry[]
  moodSuggestions  MoodFilmSuggestion[]
  moodTags         MoodFilmTag[]

  @@index([tmdbId])
}

model WatchlistEntry {
  id         String   @id @default(cuid())
  userId     String
  filmId     String
  importedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  film Film @relation(fields: [filmId], references: [id])

  @@unique([userId, filmId])
  @@index([userId])
  @@index([filmId])
}

model WatchedEntry {
  id         String   @id @default(cuid())
  userId     String
  filmId     String
  importedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  film Film @relation(fields: [filmId], references: [id])

  @@unique([userId, filmId])
  @@index([userId])
  @@index([filmId])
}

model RatingEntry {
  id         String   @id @default(cuid())
  userId     String
  filmId     String
  rating     Float    // 0.5–5.0 (half-star increments)
  importedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  film Film @relation(fields: [filmId], references: [id])

  @@unique([userId, filmId])
  @@index([userId])
  @@index([filmId])
}

model LikedEntry {
  id         String   @id @default(cuid())
  userId     String
  filmId     String
  importedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  film Film @relation(fields: [filmId], references: [id])

  @@unique([userId, filmId])
  @@index([userId])
  @@index([filmId])
}

model Interest {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  createdAt  DateTime @default(now())

  fromUser User @relation("InterestFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("InterestTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@index([toUserId, createdAt])
}

model Match {
  id            String   @id @default(cuid())
  userAId       String
  userBId       String
  score         Float
  sharedFilmIds String[]
  createdAt     DateTime @default(now())

  userA User @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([userAId, userBId])
}

model Block {
  id            String   @id @default(cuid())
  blockerId     String
  blockedUserId String
  createdAt     DateTime @default(now())

  blocker     User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedUser User @relation("Blocked", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedUserId])
  @@index([blockerId])
  @@index([blockedUserId])
}

model Report {
  id             String       @id @default(cuid())
  reporterId     String
  reportedUserId String
  reason         ReportReason
  description    String?
  status         ReportStatus @default(PENDING)
  createdAt      DateTime     @default(now())

  reporter     User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User @relation("Reported", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@index([reportedUserId])
  @@index([status])
}

model MatchScore {
  id              String   @id @default(cuid())
  userId          String
  candidateId     String
  filmOverlap     Float
  genreSimilarity Float
  totalScore      Float
  sharedFilmIds   String[]
  // Enhanced scoring fields
  likedOverlap     Float    @default(0)
  ratedOverlap     Float    @default(0)
  watchedOverlap   Float    @default(0)
  watchlistOverlap Float    @default(0)
  sharedLikedIds   String[]
  sharedRatedIds   String[]
  sharedWatchedIds String[]
  computedAt      DateTime @default(now())

  user      User @relation("ScoreUser", fields: [userId], references: [id], onDelete: Cascade)
  candidate User @relation("ScoreCandidate", fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([userId, candidateId])
  @@index([userId, totalScore(sort: Desc)])
  @@index([userId, candidateId])
}

model SeenUser {
  id         String   @id @default(cuid())
  userId     String
  seenUserId String
  seenAt     DateTime @default(now())

  user     User @relation("Viewer", fields: [userId], references: [id], onDelete: Cascade)
  seenUser User @relation("Seen", fields: [seenUserId], references: [id], onDelete: Cascade)

  @@unique([userId, seenUserId])
  @@index([userId])
}

model DailyAllocation {
  id            String   @id @default(cuid())
  userId        String
  allocatedDate DateTime
  cardCount     Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, allocatedDate])
  @@index([userId, allocatedDate])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String
  platform  String   @default("ios")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Buddy Feature ─────────────────────────────────────────

enum BuddyRequestStatus {
  OPEN
  FULL
  CLOSED
  EXPIRED
}

model BuddyRequest {
  id           String              @id @default(cuid())
  creatorId    String
  filmTitle    String
  filmYear     Int?
  posterUrl    String?
  cinemaName   String
  city         String
  date         String              // YYYY-MM-DD
  time         String              // HH:MM
  ticketUrl    String?
  maxBuddies   Int                 @default(1)
  status       BuddyRequestStatus  @default(OPEN)
  createdAt    DateTime            @default(now())
  expiresAt    DateTime

  creator   User            @relation("BuddyRequestCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  interests BuddyInterest[]
  messages  BuddyMessage[]

  @@index([status, city, date])
  @@index([creatorId])
  @@index([expiresAt])
}

model BuddyInterest {
  id        String   @id @default(cuid())
  requestId String
  userId    String
  createdAt DateTime @default(now())

  request BuddyRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User         @relation("BuddyInterestUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([requestId, userId])
  @@index([userId])
}

model BuddyMessage {
  id        String   @id @default(cuid())
  requestId String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  request BuddyRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender  User         @relation("BuddyMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
  @@index([senderId])
}

// ─── Picker Feature ─────────────────────────────────────────

enum PickerPathway {
  FILM_FIRST
  FULLY_SPECIFIED
}

enum PickerPlanStatus {
  VOTING
  CONFIRMED
  EXPIRED
  ARCHIVED
}

enum VoteStatus {
  AVAILABLE
  UNAVAILABLE
  MAYBE
}

model PickerPlan {
  id                  String           @id @default(cuid())
  organizerId         String
  filmTitle           String
  filmTmdbId          Int?
  filmPosterPath      String?
  filmYear            Int?
  pathway             PickerPathway
  city                String?
  cinema              String?
  targetDate          String?
  status              PickerPlanStatus @default(VOTING)
  confirmedShowtimeId String?          @unique
  createdAt           DateTime         @default(now())
  expiresAt           DateTime

  organizer          User               @relation("PickerPlanOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  showtimes          PickerShowtime[]   @relation("PlanShowtimes")
  participants       PickerParticipant[]
  confirmedShowtime  PickerShowtime?    @relation("ConfirmedShowtime", fields: [confirmedShowtimeId], references: [id])

  @@index([organizerId])
  @@index([status])
  @@index([expiresAt])
  @@index([status, expiresAt])
}

model PickerShowtime {
  id            String   @id @default(cuid())
  planId        String
  cinemaName    String
  cinemaCity    String
  date          String
  time          String
  ticketUrl     String?
  isManualEntry Boolean  @default(false)
  createdAt     DateTime @default(now())

  plan           PickerPlan  @relation("PlanShowtimes", fields: [planId], references: [id], onDelete: Cascade)
  votes          PickerVote[]
  confirmedPlan  PickerPlan? @relation("ConfirmedShowtime")

  @@index([planId])
  @@index([planId, date])
}

model PickerVote {
  id            String     @id @default(cuid())
  participantId String
  showtimeId    String
  status        VoteStatus
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  participant PickerParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  showtime    PickerShowtime    @relation(fields: [showtimeId], references: [id], onDelete: Cascade)

  @@unique([participantId, showtimeId])
  @@index([participantId])
  @@index([showtimeId])
  @@index([showtimeId, status])
}

model PickerParticipant {
  id           String   @id @default(cuid())
  planId       String
  userId       String?
  displayName  String
  sessionToken String?
  isOrganizer  Boolean  @default(false)
  joinedAt     DateTime @default(now())

  plan  PickerPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  user  User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes PickerVote[]

  @@unique([planId, userId])
  @@index([planId])
  @@index([userId])
  @@index([sessionToken])
}

// ─── Mood Reels Feature ─────────────────────────────────────

enum MoodType {
  NOSTALGIC
  ADVENTUROUS
  HEARTBROKEN
  HYPE
  CHILL
  ROMANTIC
  MYSTERIOUS
  INSPIRED
  MELANCHOLIC
  COZY
}

model UserMood {
  id         String   @id @default(cuid())
  userId     String
  mood       MoodType
  isActive   Boolean  @default(true)
  selectedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([mood, isActive])
  @@index([userId, selectedAt])
}

model MoodFilmSuggestion {
  id               String   @id @default(cuid())
  userId           String
  filmId           String
  mood             MoodType
  matchExplanation String
  matchStrength    Float
  source           String   @default("community")
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  film Film @relation(fields: [filmId], references: [id])

  @@index([userId, mood])
  @@index([filmId])
  @@index([userId, createdAt])
}

model MoodFilmTag {
  id         String   @id @default(cuid())
  filmId     String
  mood       MoodType
  taggedById String
  createdAt  DateTime @default(now())

  film     Film @relation(fields: [filmId], references: [id])
  taggedBy User @relation(fields: [taggedById], references: [id], onDelete: Cascade)

  @@unique([filmId, mood, taggedById])
  @@index([filmId, mood])
  @@index([mood])
  @@index([taggedById])
}
