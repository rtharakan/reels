    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@reels/letterboxd-scraper": "workspace:*",
    "@reels/matching-engine": "workspace:*",
    "@reels/shared-types": "workspace:*",
    "@reels/ui": "workspace:*",
    "@tanstack/react-query": "^5.62.0",
    "@trpc/client": "^11.0.0",
    "@trpc/next": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.2.0",
    "cheerio": "^1.2.0",
