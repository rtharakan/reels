    "react-dom": "^18.3.0",
    "resend": "^4.0.0",
    "superjson": "^2.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
